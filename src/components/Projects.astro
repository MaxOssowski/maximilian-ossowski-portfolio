---
import { projects } from "../data/projects";
---

<section id="projects" class="section defer-render" aria-labelledby="projects-title">
  <div class="container">
    <h2 id="projects-title">Projects</h2>
    <p class="section-intro">
      Selected examples of automation systems and software experiments.
    </p>

    <div class="card-grid" role="list">
      {
        projects.map((project) => (
          <article class="card" role="listitem">
            <h3>{project.title}</h3>
            <p>{project.description}</p>
            <ul class="chip-list" aria-label={`Technologies used in ${project.title}`}>
              {project.technologies.map((technology) => <li><span>{technology}</span></li>)}
            </ul>
            <a
              href={project.githubUrl}
              target="_blank"
              rel="noreferrer"
              class="text-link"
            >
              View on GitHub
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>
