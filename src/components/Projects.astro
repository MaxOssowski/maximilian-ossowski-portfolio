---
import { projects } from "../data/projects";
---

<section
  id="projects"
  class="section defer-render"
  aria-labelledby="projects-title"
>
  <div class="container">
    <h2 id="projects-title">Projects</h2>
    <p class="section-intro">
      Selected examples of automation systems and software experiments.
    </p>

    <ul class="card-grid project-list">
      {
        projects.map((project) => (
          <li class="project-item">
            <article class="card">
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <ul
                class="chip-list"
                aria-label={`Technologies used in ${project.title}`}
              >
                {project.technologieis.map((technology) => (
                  <li>
                    <span>{technology}</span>
                  </li>
                ))}
              </ul>
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noreferrer"
                class="text-link"
              >
                View on GitHub
              </a>
            </article>
          </li>
        ))
      }
    </ul>
  </div>
</section>
